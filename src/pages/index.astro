---
const matches = [
  { league: "Champions League", teams: "Barcelona vs Real Madrid", odds: [2.1, 3.5, 2.0] },
  { league: "Premier League", teams: "Man City vs Liverpool", odds: [1.9, 3.3, 2.2] },
  { league: "Eredivisie", teams: "Ajax vs PSV", odds: [1.8, 3.2, 2.4] }
];
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AmicFormula</title>

<style>
body {
  margin: 0;
  font-family: Inter, Arial;
  background: #0b1220;
  color: white;
}

/* NAVBAR */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px 25px;
  background: #020617;
  border-bottom: 1px solid #1e293b;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo span {
  font-weight: bold;
  font-size: 20px;
}

.wallet {
  background: #f97316;
  padding: 8px 15px;
  border-radius: 6px;
  cursor: pointer;
}

/* LAYOUT */
.container {
  display: grid;
  grid-template-columns: 3fr 1fr;
}

/* MATCHES */
.match {
  background: #111827;
  margin: 15px;
  padding: 15px;
  border-radius: 10px;
  transition: 0.2s;
}

.match:hover {
  background: #1f2937;
}

.league {
  font-size: 12px;
  color: #94a3b8;
}

.odds {
  margin-top: 10px;
}

.odds button {
  margin-right: 10px;
  padding: 10px 15px;
  border: none;
  border-radius: 6px;
  background: #1e293b;
  color: white;
  cursor: pointer;
}

.odds button:hover {
  background: #f97316;
}

/* BET SLIP */
.betslip {
  background: #020617;
  padding: 20px;
  border-left: 1px solid #1e293b;
}

input {
  width: 100%;
  padding: 10px;
  margin-top: 10px;
  background: #0f172a;
  border: 1px solid #334155;
  color: white;
}

.place {
  margin-top: 10px;
  width: 100%;
  padding: 10px;
  background: #22c55e;
  border: none;
  cursor: pointer;
}
</style>
</head>

<body>

<nav>
  <div class="logo">
    <svg width="35" height="35" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="50" fill="#FF6B00"/>
      <path d="M25 70 L50 30 L75 70 L65 70 L50 45 L35 70 Z" fill="white"/>
    </svg>
    <span>AmicFormula</span>
  </div>

  <div class="wallet" onclick="connectWallet()">
    Connect Wallet
  </div>
</nav>

<div class="container">
  <div>
    {matches.map(m => (
      <div class="match">
        <div class="league">{m.league}</div>
        <h3>{m.teams}</h3>
        <div class="odds">
          <button onclick={`selectBet("${m.teams}", ${m.odds[0]})`}>1 {m.odds[0]}</button>
          <button onclick={`selectBet("${m.teams}", ${m.odds[1]})`}>X {m.odds[1]}</button>
          <button onclick={`selectBet("${m.teams}", ${m.odds[2]})`}>2 {m.odds[2]}</button>
        </div>
      </div>
    ))}
  </div>

  <div class="betslip">
    <h3>Bet Slip</h3>
    <p id="walletStatus">Wallet: Not connected</p>
    <p id="selection">No bet selected</p>
    <input id="stake" type="number" placeholder="Stake" />
    <button class="place" onclick="placeBet()">Place Bet</button>
  </div>
</div>

<script>
let selectedBet = null;

/* DEMO WALLET */
async function connectWallet() {
  if (window.ethereum) {
    try {
      const accounts = await window.ethereum.request({
        method: "eth_requestAccounts"
      });
      document.getElementById("walletStatus").innerText =
        "Wallet: " + accounts[0].slice(0,6) + "...";
    } catch {
      alert("Connection rejected");
    }
  } else {
    alert("Install MetaMask");
  }
}

function selectBet(teams, odds) {
  selectedBet = { teams, odds };
  document.getElementById("selection").innerText =
    teams + " @ " + odds;
}

function placeBet() {
  if (!selectedBet) {
    alert("Select a bet first");
    return;
  }
  alert("Demo bet placed (no real crypto used)");
}
</script>

</body>
</html>
