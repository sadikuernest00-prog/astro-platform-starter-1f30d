<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Amicbridge | Premium Women's Underwear</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --bg: #fffaf7;
        --text: #1e1e1e;
        --muted: #6b6b6b;
        --primary: #d96b86;
        --dark: #111111;
        --card: #ffffff;
        --border: #ece7e4;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Inter', sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      .container {
        width: min(1200px, 92%);
        margin: auto;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255, 250, 247, 0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
      }

      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 0;
      }

      .logo {
        font-size: 1.6rem;
        font-weight: 800;
        letter-spacing: -1px;
      }

      .logo span {
        color: var(--primary);
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        color: var(--muted);
        font-weight: 500;
      }

      .hero {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 4rem;
        align-items: center;
        min-height: 90vh;
        padding: 4rem 0;
      }

      .hero-text h1 {
        font-size: 4.5rem;
        line-height: 1;
        margin-bottom: 1.5rem;
        letter-spacing: -3px;
      }

      .hero-text p {
        color: var(--muted);
        font-size: 1.1rem;
        margin-bottom: 2rem;
        max-width: 500px;
      }

      .hero-buttons {
        display: flex;
        gap: 1rem;
      }

      .btn {
        padding: 1rem 1.8rem;
        border-radius: 999px;
        font-weight: 600;
        transition: 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .btn-primary {
        background: var(--dark);
        color: white;
      }

      .btn-primary:hover {
        opacity: 0.9;
        transform: translateY(-2px);
      }

      .btn-secondary {
        border: 1px solid var(--border);
        background: white;
      }

      .hero-image img {
        width: 100%;
        height: 720px;
        object-fit: cover;
        border-radius: 32px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
      }

      .section-title {
        text-align: center;
        margin-bottom: 3rem;
      }

      .section-title h2 {
        font-size: 2.8rem;
        margin-bottom: 0.8rem;
      }

      .section-title p {
        color: var(--muted);
      }

      .products {
        padding: 6rem 0;
      }

      .product-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
      }

      .product-card {
        background: var(--card);
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--border);
        transition: 0.3s ease;
      }

      .product-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
      }

      .product-card img {
        width: 100%;
        height: 360px;
        object-fit: cover;
      }

      .product-info {
        padding: 1.5rem;
      }

      .product-info h3 {
        font-size: 1.2rem;
        margin-bottom: 0.4rem;
      }

      .price {
        color: var(--primary);
        font-weight: 700;
        margin-bottom: 1rem;
      }

      .features {
        padding: 6rem 0;
      }

      .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
      }

      .feature-box {
        background: white;
        padding: 2rem;
        border-radius: 24px;
        border: 1px solid var(--border);
      }

      .feature-box h3 {
        margin-bottom: 1rem;
      }

      .feature-box p {
        color: var(--muted);
      }

      .newsletter {
        padding: 6rem 0;
      }

      .newsletter-box {
        background: var(--dark);
        color: white;
        border-radius: 32px;
        padding: 4rem;
        text-align: center;
      }

      .newsletter-box h2 {
        font-size: 3rem;
        margin-bottom: 1rem;
      }

      .newsletter-box p {
        color: rgba(255,255,255,0.7);
        margin-bottom: 2rem;
      }

      .newsletter-form {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .newsletter-form input {
        width: 320px;
        padding: 1rem 1.2rem;
        border-radius: 999px;
        border: none;
        outline: none;
      }

      footer {
        padding: 2rem 0 3rem;
        text-align: center;
        color: var(--muted);
      }

      @media (max-width: 900px) {
        .hero,
        .product-grid,
        .feature-grid {
          grid-template-columns: 1fr;
        }

        .hero-text h1 {
          font-size: 3rem;
        }

        .hero-image img {
          height: 500px;
        }

        .nav-links {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <div class="container">
        <nav>
          <div class="logo">Amic<span>bridge</span></div>

          <div class="nav-links">
            <a href="#shop">Shop</a>
            <a href="#features">Why Us</a>
            <a href="#newsletter">Newsletter</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero container">
        <div class="hero-text">
          <p>Luxury Comfort • Elegant Design</p>

          <h1>
            Premium underwear made for confidence.
          </h1>

          <p>
            Discover modern essentials designed for comfort, softness, and confidence. Elegant collections made for everyday wear.
          </p>

          <div class="hero-buttons">
            <a href="#shop" class="btn btn-primary">Shop Collection</a>
            <a href="#features" class="btn btn-secondary">Learn More</a>
          </div>
        </div>

        <div class="hero-image">
          <img
            src="https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?q=80&w=1400&auto=format&fit=crop"
            alt="Women's fashion"
          />
        </div>
      </section>

      <section class="products container" id="shop">
        <div class="section-title">
          <h2>Best Sellers</h2>
          <p>Comfort-focused styles women love.</p>
        </div>

        <div class="product-grid">
          {
            products.map((product) => (
              <div class="product-card">
                <img src={product.image} alt={product.name} />

                <div class="product-info">
                  <h3>{product.name}</h3>
                  <div class="price">{product.price}</div>

                  <a href="#" class="btn btn-primary">
                    Add to Cart
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="features container" id="features">
        <div class="section-title">
          <h2>Why Customers Love Amicbridge</h2>
          <p>Built with quality, comfort, and elegance in mind.</p>
        </div>

        <div class="feature-grid">
          <div class="feature-box">
            <h3>Soft Premium Fabrics</h3>
            <p>
              Designed with breathable materials for all-day comfort and support.
            </p>
          </div>

          <div class="feature-box">
            <h3>Elegant Minimal Design</h3>
            <p>
              A clean modern style that feels premium and trustworthy.
            </p>
          </div>

          <div class="feature-box">
            <h3>Fast Worldwide Shipping</h3>
            <p>
              Reliable delivery with easy returns to create confidence for buyers.
            </p>
          </div>
        </div>
      </section>

      <section class="newsletter container" id="newsletter">
        <div class="newsletter-box">
          <h2>Get 10% Off Your First Order</h2>

          <p>
            Join the Amicbridge newsletter for exclusive launches and special offers.
          </p>

          <form class="newsletter-form">
            <input type="email" placeholder="Enter your email" />
            <button class="btn btn-primary">Subscribe</button>
          </form>
        </div>
      </section>
    </main>

    <footer>
      <div class="container">
        © 2026 Amicbridge. All rights reserved.
      </div>
    </footer>
  </body>
</html>
```

