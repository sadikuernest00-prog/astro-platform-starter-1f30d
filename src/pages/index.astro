---
const products = [
  {
    name: "Elegant Lace Set",
    price: "599 NOK",
    image: "/images/white-lace.jpg",
    badge: "Best Seller"
  },
  {
    name: "Midnight Black Collection",
    price: "549 NOK",
    image: "/images/black-set.jpg",
    badge: "New"
  },
  {
    name: "Luxury Satin Sleepwear",
    price: "599 NOK",
    image: "/images/satin-set.jpg",
    badge: "Luxury"
  },
  {
    name: "Comfort Seamless Bra",
    price: "449 NOK",
    image: "/images/white-bra.jpg",
    badge: "Popular"
  },
  {
    name: "Black Comfort Bra",
    price: "449 NOK",
    image: "/images/black-bra.jpg",
    badge: "Trending"
  },
  {
    name: "Nude Comfort Bra",
    price: "449 NOK",
    image: "/images/nude-bra.jpg",
    badge: "Soft Fit"
  },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Amicbridge | Luxury Women's Underwear</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <style>

    :root {
      --bg: #faf7f5;
      --white: #ffffff;
      --text: #111111;
      --muted: #777777;
      --gold: #d4a373;
      --border: #ece7e4;
      --dark: #121212;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    img {
      display: block;
    }

    .container {
      width: min(1280px, 92%);
      margin: auto;
    }

    header {
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 999;
      backdrop-filter: blur(18px);
      background: rgba(255,255,255,0.75);
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.3rem 0;
    }

    .logo {
      font-size: 2rem;
      font-weight: 900;
      letter-spacing: -2px;
    }

    .logo span {
      color: var(--gold);
    }

    .nav-right {
      display: flex;
      gap: 2rem;
      align-items: center;
    }

    .nav-links {
      display: flex;
      gap: 1.8rem;
      color: var(--muted);
      font-weight: 500;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 2rem;
      border-radius: 999px;
      font-weight: 700;
      transition: 0.35s ease;
      cursor: pointer;
      border: none;
    }

    .btn-dark {
      background: var(--dark);
      color: white;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .btn-dark:hover {
      transform: translateY(-3px);
      opacity: 0.95;
    }

    .btn-light {
      background: white;
      color: black;
      border: 1px solid var(--border);
    }

    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
      padding-top: 8rem;
      padding-bottom: 5rem;
    }

    .hero-text small {
      display: inline-block;
      padding: 0.6rem 1rem;
      background: white;
      border-radius: 999px;
      border: 1px solid var(--border);
      margin-bottom: 1.5rem;
      color: var(--gold);
      font-weight: 700;
    }

    .hero h1 {
      font-size: 5.5rem;
      line-height: 0.95;
      letter-spacing: -5px;
      margin-bottom: 2rem;
      font-weight: 900;
    }

    .hero p {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 560px;
      margin-bottom: 2.2rem;
      line-height: 1.8;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .hero-image {
      position: relative;
    }

    .hero-image img {
      width: 100%;
      height: 820px;
      object-fit: cover;
      border-radius: 40px;
      box-shadow: 0 30px 80px rgba(0,0,0,0.12);
    }

    .floating-card {
      position: absolute;
      bottom: 30px;
      left: -30px;
      background: white;
      padding: 1.2rem 1.5rem;
      border-radius: 24px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.12);
    }

    .floating-card h4 {
      font-size: 1.1rem;
      margin-bottom: 0.4rem;
    }

    .floating-card p {
      color: var(--muted);
      font-size: 0.95rem;
    }

    .section {
      padding: 7rem 0;
    }

    .section-title {
      text-align: center;
      margin-bottom: 4rem;
    }

    .section-title h2 {
      font-size: 4rem;
      letter-spacing: -3px;
      margin-bottom: 1rem;
    }

    .section-title p {
      color: var(--muted);
      font-size: 1.05rem;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .product-card {
      background: white;
      border-radius: 32px;
      overflow: hidden;
      border: 1px solid var(--border);
      transition: 0.4s ease;
      position: relative;
    }

    .product-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 30px 60px rgba(0,0,0,0.08);
    }

    .badge {
      position: absolute;
      top: 20px;
      left: 20px;
      background: white;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 700;
      z-index: 5;
    }

    .product-card img {
      width: 100%;
      height: 460px;
      object-fit: cover;
    }

    .product-info {
      padding: 1.8rem;
    }

    .product-info h3 {
      font-size: 1.3rem;
      margin-bottom: 0.6rem;
    }

    .price {
      color: var(--gold);
      font-size: 1.3rem;
      font-weight: 800;
      margin-bottom: 1.3rem;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .feature-box {
      background: white;
      padding: 2.5rem;
      border-radius: 32px;
      border: 1px solid var(--border);
      transition: 0.3s ease;
    }

    .feature-box:hover {
      transform: translateY(-6px);
    }

    .feature-box h3 {
      margin-bottom: 1rem;
      font-size: 1.4rem;
    }

    .feature-box p {
      color: var(--muted);
      line-height: 1.8;
    }

    .newsletter-box {
      background: linear-gradient(135deg, #111111, #222222);
      color: white;
      border-radius: 40px;
      padding: 5rem;
      text-align: center;
      overflow: hidden;
      position: relative;
    }

    .newsletter-box h2 {
      font-size: 4rem;
      margin-bottom: 1rem;
      letter-spacing: -3px;
    }

    .newsletter-box p {
      color: rgba(255,255,255,0.7);
      max-width: 700px;
      margin: auto;
      margin-bottom: 2rem;
      line-height: 1.8;
    }

    .newsletter-form {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .newsletter-form input {
      width: 360px;
      padding: 1.1rem 1.4rem;
      border-radius: 999px;
      border: none;
      outline: none;
      font-size: 1rem;
    }

    footer {
      padding: 3rem 0;
      text-align: center;
      color: var(--muted);
    }

    @media(max-width: 980px) {

      .hero,
      .product-grid,
      .features-grid {
        grid-template-columns: 1fr;
      }

      .hero h1 {
        font-size: 3.8rem;
      }

      .section-title h2 {
        font-size: 2.8rem;
      }

      .newsletter-box h2 {
        font-size: 2.8rem;
      }

      .hero-image img {
        height: 600px;
      }

      .nav-links {
        display: none;
      }

      .floating-card {
        left: 20px;
      }
    }

  </style>
</head>

<body>

<header>
  <div class="container">
    <nav>

      <div class="logo">
        Amic<span>bridge</span>
      </div>

      <div class="nav-right">

        <div class="nav-links">
          <a href="#shop">Shop</a>
          <a href="#why">Why Us</a>
          <a href="#newsletter">Newsletter</a>
        </div>

        <a href="#shop" class="btn btn-dark">
          Shop Now
        </a>

      </div>

    </nav>
  </div>
</header>

<main>

<section class="hero container">

  <div class="hero-text">

    <small>Luxury Comfort • Premium Quality</small>

    <h1>
      Underwear designed to feel beautiful.
    </h1>

    <p>
      Discover premium collections crafted for elegance, softness and confidence. 
      Minimal luxury designed for modern women.
    </p>

    <div class="hero-buttons">

      <a href="#shop" class="btn btn-dark">
        Explore Collection
      </a>

      <a href="#why" class="btn btn-light">
        Why Amicbridge
      </a>

    </div>

  </div>

  <div class="hero-image">

    <img
      src="/images/hero.jpg"
      alt="Luxury fashion"
    />

    <div class="floating-card">
      <h4>Trusted by Women</h4>
      <p>Premium comfort with elegant style.</p>
    </div>

  </div>

</section>

<section class="section container" id="shop">

  <div class="section-title">

    <h2>Featured Collection</h2>

    <p>
      Designed with premium fabrics and timeless elegance.
    </p>

  </div>

  <div class="product-grid">

    {
      products.map((product) => (

        <div class="product-card">

          <div class="badge">
            {product.badge}
          </div>

          <img
            src={product.image}
            alt={product.name}
          />

          <div class="product-info">

            <h3>{product.name}</h3>

            <div class="price">
              {product.price}
            </div>

            <a href="#" class="btn btn-dark">
              Add to Cart
            </a>

          </div>

        </div>

      ))
    }

  </div>

</section>

<section class="section container" id="why">

  <div class="section-title">

    <h2>Why Women Love Amicbridge</h2>

    <p>
      Luxury comfort made for confidence and everyday elegance.
    </p>

  </div>

  <div class="features-grid">

    <div class="feature-box">

      <h3>Premium Fabrics</h3>

      <p>
        Soft breathable materials designed for all-day comfort and luxury feel.
      </p>

    </div>

    <div class="feature-box">

      <h3>Elegant Design</h3>

      <p>
        Modern minimalist collections inspired by timeless feminine style.
      </p>

    </div>

    <div class="feature-box">

      <h3>Fast Worldwide Shipping</h3>

      <p>
        Reliable delivery with easy returns to create confidence when shopping.
      </p>

    </div>

  </div>

</section>

<section class="section container" id="newsletter">

  <div class="newsletter-box">

    <h2>Get 10% Off Your First Order</h2>

    <p>
      Join the Amicbridge newsletter for exclusive launches, premium collections and special offers.
    </p>

    <form class="newsletter-form">

      <input
        type="email"
        placeholder="Enter your email address"
      />

      <button class="btn btn-dark">
        Subscribe
      </button>

    </form>

  </div>

</section>

</main>

<footer>
  © 2026 Amicbridge. Luxury Women's Underwear.
</footer>

</body>
</html>
