---
const matches = [
  { league: "Champions League", teams: "Barcelona vs Real Madrid", odds: [2, 3, 2] },
  { league: "Premier League", teams: "Man City vs Liverpool", odds: [1, 3, 2] },
  { league: "Eredivisie", teams: "Ajax vs PSV", odds: [1, 2, 2] }
];
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AmicFormula Web3</title>

<style>
body {
  margin: 0;
  font-family: Arial;
  background: #0b1220;
  color: white;
}

nav {
  display:flex;
  justify-content:space-between;
  padding:15px 25px;
  background:#020617;
  border-bottom:1px solid #1e293b;
}

.logo {
  display:flex;
  align-items:center;
  gap:10px;
  font-weight:bold;
}

.wallet {
  background:#f97316;
  padding:8px 12px;
  border-radius:6px;
  cursor:pointer;
}

.container {
  display:grid;
  grid-template-columns:3fr 1fr;
}

.match {
  background:#111827;
  margin:15px;
  padding:15px;
  border-radius:10px;
}

.odds button {
  margin-right:8px;
  padding:10px;
  border:none;
  border-radius:6px;
  background:#1e293b;
  color:white;
  cursor:pointer;
}

.odds button:hover {
  background:#f97316;
}

.betslip {
  background:#020617;
  padding:20px;
  border-left:1px solid #1e293b;
}

input {
  width:100%;
  padding:10px;
  margin-top:10px;
  background:#0f172a;
  border:1px solid #334155;
  color:white;
}

.place {
  margin-top:10px;
  width:100%;
  padding:10px;
  background:#22c55e;
  border:none;
  cursor:pointer;
}
</style>
</head>

<body>

<nav>
  <div class="logo">
    <span>🟠 AmicFormula</span>
  </div>

  <div class="wallet" onclick="connectWallet()">
    Connect Wallet
  </div>
</nav>

<div class="container">

  <div>
    {matches.map(m => (
      <div class="match">
        <div style="color:#94a3b8;font-size:12px">{m.league}</div>
        <h3>{m.teams}</h3>

        <div class="odds">
          <button onclick={`selectBet("${m.teams}", ${m.odds[0]})`}>1 {m.odds[0]}</button>
          <button onclick={`selectBet("${m.teams}", ${m.odds[1]})`}>X {m.odds[1]}</button>
          <button onclick={`selectBet("${m.teams}", ${m.odds[2]})`}>2 {m.odds[2]}</button>
        </div>
      </div>
    ))}
  </div>

  <div class="betslip">
    <h3>Web3 Bet Slip</h3>

    <p id="walletStatus">Wallet: Not connected</p>
    <p id="selection">No bet selected</p>

    <input id="stake" type="number" placeholder="Stake (ETH)" />

    <button class="place" onclick="placeBet()">
      Place On-Chain Bet
    </button>
  </div>

</div>

<script>
import { ethers } from "https://cdn.jsdelivr.net/npm/ethers@6.13.4/+esm";

let selectedBet = null;
let signer;
let contract;

// 🔴 PUT YOUR CONTRACT ADDRESS HERE
const contractAddress = "PASTE_YOUR_CONTRACT_ADDRESS";

// ABI from your Solidity contract
const abi = [
  "function placeBet(uint256 odds) payable"
];

async function connectWallet() {
  if (!window.ethereum) {
    alert("Install MetaMask");
    return;
  }

  const provider = new ethers.BrowserProvider(window.ethereum);
  await provider.send("eth_requestAccounts", []);
  signer = await provider.getSigner();

  const address = await signer.getAddress();
  document.getElementById("walletStatus").innerText =
    "Wallet: " + address.slice(0,6) + "...";

  contract = new ethers.Contract(contractAddress, abi, signer);
}

function selectBet(teams, odds) {
  selectedBet = { teams, odds };
  document.getElementById("selection").innerText =
    teams + " @ " + odds;
}

async function placeBet() {
  if (!contract) {
    alert("Connect wallet first");
    return;
  }

  if (!selectedBet) {
    alert("Select a bet");
    return;
  }

  const stake = document.getElementById("stake").value;

  if (!stake || stake <= 0) {
    alert("Invalid stake");
    return;
  }

  try {
    const tx = await contract.placeBet(selectedBet.odds, {
      value: ethers.parseEther(stake)
    });

    await tx.wait();
    alert("Bet placed on blockchain!");
  } catch (err) {
    console.error(err);
    alert("Transaction failed");
  }
}
</script>

</body>
</html>
