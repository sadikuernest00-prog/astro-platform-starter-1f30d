
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>AmicBridge Dashboard</title>
</head>

<body>

<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <h2 class="logo">AMIC<span>BRIDGE</span></h2>

    <nav>
      <a href="#">Dashboard</a>
      <a href="#">Investments</a>
      <a href="#">Opportunities</a>
      <a href="#">Agreements</a>
      <a href="#contact">Contact</a>
    </nav>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <!-- TOP BAR -->
    <div class="topbar">
      <h1>Investor Dashboard</h1>
      <a href="mailto:sadikuernest00@gmail.com" class="btn">Email CEO</a>
    </div>

    <!-- STATS -->
    <section class="stats">
      <div class="card">
        <h3>Active Opportunities</h3>
        <p>5+</p>
      </div>

      <div class="card">
        <h3>Structured Deals</h3>
        <p>12</p>
      </div>

      <div class="card">
        <h3>Investor Access</h3>
        <p>Open</p>
      </div>
    </section>

    <!-- HERO -->
    <section class="hero card">
      <h2>Grow your capital with structured opportunities</h2>
      <p>
        AmicBridge connects private lenders with vetted projects. 
        We focus on agreements, transparency, and long-term growth.
      </p>

      <div class="buttons">
        <a href="#contact" class="btn primary">Get Started</a>
        <a href="#" class="btn secondary">How it works</a>
      </div>
    </section>

    <!-- OPPORTUNITIES -->
    <section class="section">
      <h2>Featured Opportunities</h2>

      <div class="grid">
        <div class="card">
          <h3>Real Estate Development</h3>
          <p>Structured funding for property development projects.</p>
        </div>

        <div class="card">
          <h3>Private Lending Pools</h3>
          <p>Diversified lending opportunities with agreements.</p>
        </div>

        <div class="card">
          <h3>Business Expansion</h3>
          <p>Funding growth-stage businesses with clear plans.</p>
        </div>
      </div>
    </section>

    <!-- CONTACT / SIGNUP -->
    <section id="contact" class="section">
      <h2>Join as Investor</h2>

      <form class="card form">
        <input type="text" placeholder="Full Name" required />
        <input type="email" placeholder="Email Address" required />
        <input type="text" placeholder="Investment Amount (optional)" />
        <textarea placeholder="Your message"></textarea>

        <button class="btn primary">Submit Request</button>
      </form>

      <p class="contact-alt">
        Or contact directly: 
        <a href="mailto:sadikuernest00@gmail.com">sadikuernest00@gmail.com</a>
      </p>
    </section>

  </main>

</div>

</body>
</html>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #f4f6fb;
}

/* LAYOUT */
.layout {
  display: flex;
}

/* SIDEBAR */
.sidebar {
  width: 220px;
  background: #111827;
  color: white;
  min-height: 100vh;
  padding: 20px;
}

.sidebar .logo {
  margin-bottom: 30px;
}

.sidebar .logo span {
  color: #3b82f6;
}

.sidebar a {
  display: block;
  color: #ccc;
  text-decoration: none;
  margin: 10px 0;
}

.sidebar a:hover {
  color: white;
}

/* MAIN */
.main {
  flex: 1;
  padding: 20px 40px;
}

/* TOPBAR */
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* BUTTON */
.btn {
  padding: 10px 16px;
  border-radius: 8px;
  text-decoration: none;
  background: #e5e7eb;
  color: #111;
}

.primary {
  background: #3b82f6;
  color: white;
}

.secondary {
  background: #e5e7eb;
}

/* CARDS */
.card {
  background: white;
  padding: 20px;
  border-radius: 12px;
  margin-top: 20px;
  border: 1px solid #ddd;
}

/* STATS */
.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

/* HERO */
.hero h2 {
  margin-bottom: 10px;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

/* FORM */
.form {
  display: flex;
  flex-direction: column;
}

.form input,
.form textarea {
  margin-bottom: 10px;
  padding: 10px;
  border-radius: 6px;
  border: 1px solid #ccc;
}

/* CONTACT TEXT */
.contact-alt {
  margin-top: 15px;
  font-size: 14px;
}

/* MOBILE */
@media (max-width: 800px) {
  .layout {
    flex-direction: column;
  }

  .sidebar {
    width: 100%;
    display: flex;
    justify-content: space-around;
  }

  .stats,
  .grid {
    grid-template-columns: 1fr;
  }
}
</style>
